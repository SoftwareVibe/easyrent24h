    "azionistato": "CREATE TABLE `azionistato` (\n  `id` int NOT NULL,\n  `statoIn` enum('Attivo','Da Attivare','Sospeso') NOT NULL,\n  `statoOut` enum('Attivo','Da Attivare','Sospeso') NOT NULL,\n  `codificaIn` varchar(30) NOT NULL,\n  `codificaOut` int NOT NULL\n) ENGINE=InnoDB DEFAULT CHARSET=latin1;",
